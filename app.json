{
  "expo": {
    "name": "99personal",
    "slug": "99personal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ChatGPT_Image_9_de_jul._de_2026,_21_23_46-Photoroom.png",
    "scheme": "99personal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.personal99"
    },
    "android": {
      "package": "com.personal99"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/ChatGPT_Image_9_de_jul._de_2026,_21_23_46-Photoroom.png",
      "title": "99personal"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
