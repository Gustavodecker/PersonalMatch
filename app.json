{
  "expo": {
    "name": "99 Personal",
    "slug": "99personal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ChatGPT_Image_9_de_jul._de_2026,_21_23_46-Photoroom.png",
    "scheme": "personal99",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.personal99",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.personal99"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/ChatGPT_Image_9_de_jul._de_2026,_21_23_46-Photoroom.png",
      "title": "99 Personal"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e7f072a-ce8d-401a-87c3-47f07236dbfc"
      }
    },
    "owner": "gustavo.miguel"
  }
}
